# ═══════════════════════════════════════════════════════════
#  IFX-VPN Bot — шаблон конфигурации окружения
#  Скопируйте этот файл в .env и заполните своими данными.
#  Файл .env никогда не должен попадать в Git-репозиторий!
# ═══════════════════════════════════════════════════════════
 
# ─── Основные настройки бота ────────────────────────────────
# Токен бота, полученный от @BotFather
BOT_TOKEN=1234567890:ABCdefGhIJKlmNoPQRsTUVwXyZ
 
# Username бота без @ (нужен для генерации реферальных ссылок)
# Получить можно у @BotFather командой /mybots
BOT_USERNAME=your_bot_username
 
# ID администраторов через запятую (без пробелов)
# Получить свой ID можно у @userinfobot
ADMIN_IDS=987654321,112233445
 
# ─── Цены (числа, точка как разделитель) ────────────────────
PRICE_RUB=100
PRICE_USDT=1.5
 
# ─── Подписка ───────────────────────────────────────────────
# Длительность пробного периода в днях
TRIAL_DAYS=3
 
# Длительность платной подписки в днях
SUBSCRIPTION_DAYS=30
 
# ─── Реферальная программа ──────────────────────────────────
# Бонусных дней рефереру за то, что приглашённый активировал триал
REFERRAL_TRIAL_BONUS=3
 
# Бонусных дней рефереру за то, что приглашённый оплатил подписку
REFERRAL_PAID_BONUS=7
 
# ─── Напоминания о продлении ────────────────────────────────
# За сколько дней до истечения слать напоминания (через запятую)
REMINDER_DAYS=3,1
 
# ─── Реквизиты СБП ──────────────────────────────────────────
# Номер телефона для перевода по СБП
SBP_NUMBER=+79876543210
 
# Название банка (необязательно, но улучшает UX)
SBP_BANK=А-Банк
 
# Имя получателя (необязательно)
SBP_NAME=Иван Т.
 
# ─── Криптокошельки (USDT) ──────────────────────────────────
# Оставьте пустым или удалите строку, чтобы скрыть сеть в боте
WALLET_TRC20=TWxA7g...
WALLET_ERC20=0x386k...
WALLET_BEP20=0x386k...
WALLET_TON=UABF...